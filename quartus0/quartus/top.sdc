# DE10-Lite board clock: 50 MHz, period = 20 ns.
create_clock -name CLK -period 20.000 [get_ports {CLK}]
derive_pll_clocks
derive_clock_uncertainty

# Debug/JTAG pins are virtual in this project pin plan.
# Keep TCK as a very slow asynchronous debug clock so it does not pollute
# the SoC functional CLK timing summary.
create_clock -name TCK -period 100.000 [get_ports {TCK}]
set_clock_groups -asynchronous -group [get_clocks {CLK}] -group [get_clocks {TCK}]

# SDRAM_CLK is generated by the PLL c0 output in top.v. The PLL now divides the
# 50 MHz board clock by 2, so SDRAM_CLK is 25 MHz.
# These board-level I/O
# numbers are conservative placeholders for bring-up; refine them from the SDRAM
# datasheet and board trace timing before treating SDRAM timing as signed off.
create_generated_clock -name SDRAM_CLK_OUT -source [get_ports {CLK}] -divide_by 2 [get_ports {SDRAM_CLK}]

set sdram_addr_ctrl_ports [get_ports {SDRAM_CKE SDRAM_CSn SDRAM_RASn SDRAM_CASn SDRAM_WEn SDRAM_ADDR[*] SDRAM_BA[*] SDRAM_DQM[*]}]
set sdram_dq_ports        [get_ports {SDRAM_DQ[*]}]

set_output_delay -clock [get_clocks {SDRAM_CLK_OUT}] -max 8.000 $sdram_addr_ctrl_ports
set_output_delay -clock [get_clocks {SDRAM_CLK_OUT}] -min -1.000 $sdram_addr_ctrl_ports
set_output_delay -clock [get_clocks {SDRAM_CLK_OUT}] -max 8.000 $sdram_dq_ports
set_output_delay -clock [get_clocks {SDRAM_CLK_OUT}] -min -1.000 $sdram_dq_ports
set_input_delay  -clock [get_clocks {SDRAM_CLK_OUT}] -max 8.000 $sdram_dq_ports
set_input_delay  -clock [get_clocks {SDRAM_CLK_OUT}] -min 1.000 $sdram_dq_ports

# RESETn is an external push-button style asynchronous reset.
# This avoids recovery/removal analysis from an unconstrained external input.
set_false_path -from [get_ports {RESETn}]

# External inputs are asynchronous or board-level sources for this first bring-up.
# GPIO key/UART/timer inputs are sampled by software/peripheral logic, and i2s_sd
# is related to the generated I2S clock at board level rather than a TimeQuest
# synchronous input to CLK.
set_false_path -from [get_ports {b_pad_gpio_porta[*]}]
set_false_path -from [get_ports {uart1_rxd uart2_rxd timer0_extin timer1_extin i2s_sd}]
set_false_path -to   [get_ports {b_pad_gpio_porta[*]}]
set_false_path -to   [get_ports {uart1_txd uart2_txd i2s_sck i2s_ws}]

# Unused virtual debug data pins.
set_false_path -from [get_ports {TDI TMS}]
set_false_path -to   [get_ports {TDO TMS}]
